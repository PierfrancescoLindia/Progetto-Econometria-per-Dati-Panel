# ============================================================
# PROGETTO ECONOMETRIA PER DATI PANEL
# PARTE 1.2 - DESCRIZIONE DEL DATASET
# Dataset: Africa Capital Structure Firms
# ============================================================


# ============================================================
# 0. PULIZIA AMBIENTE
# ============================================================

rm(list = ls())

cat("\014")   # pulisce la console in RStudio


# ============================================================
# 1. INSTALLAZIONE E CARICAMENTO PACCHETTI
# ============================================================

# Installare i pacchetti solo se non presenti
packages <- c(
  "readr",
  "dplyr",
  "tidyr",
  "janitor",
  "plm",
  "ggplot2",
  "skimr",
  "psych",
  "knitr"
)

installed_packages <- rownames(installed.packages())

for (p in packages) {
  if (!(p %in% installed_packages)) {
    install.packages(p)
  }
}

# Caricamento pacchetti
library(readr)
library(dplyr)
library(tidyr)
library(janitor)
library(plm)
library(ggplot2)
library(skimr)
library(psych)
library(knitr)


# ============================================================
# 2. IMPORTAZIONE DEL DATASET
# ============================================================

# ATTENZIONE:
# Impostare la working directory nella cartella in cui si trova il file CSV.
# In alternativa, inserire il percorso completo del file.

df_raw <- read_csv("africa-capital-structure-firms.csv")

# Prime osservazioni
head(df_raw)

# Dimensioni dataset
dim(df_raw)

# Nomi originali delle variabili
names(df_raw)

# Struttura del dataset
str(df_raw)


# ============================================================
# 3. PULIZIA NOMI VARIABILI
# ============================================================

# Pulizia dei nomi delle variabili:
# - elimina spazi
# - elimina parentesi
# - converte tutto in minuscolo
# - usa underscore

df <- df_raw %>%
  clean_names()

# Controllo nuovi nomi
names(df)

# Visualizzazione prime righe dopo la pulizia
head(df)


# ============================================================
# 4. CONTROLLO DELLE VARIABILI CHIAVE
# ============================================================

# Le variabili panel principali sono:
# company_id = identificativo impresa
# year       = anno

# Controllo presenza variabili chiave
"company_id" %in% names(df)
"year" %in% names(df)

# Numero totale di osservazioni
n_obs <- nrow(df)

# Numero di imprese
n_firms <- n_distinct(df$company_id)

# Numero di anni
n_years <- n_distinct(df$year)

# Intervallo temporale
year_min <- min(df$year, na.rm = TRUE)
year_max <- max(df$year, na.rm = TRUE)

# Stampa risultati principali
cat("Numero totale di osservazioni:", n_obs, "\n")
cat("Numero di imprese:", n_firms, "\n")
cat("Numero di anni:", n_years, "\n")
cat("Periodo osservato:", year_min, "-", year_max, "\n")


# ============================================================
# 5. CONTROLLO DUPLICATI IMPRESA-ANNO
# ============================================================

duplicates <- df %>%
  count(company_id, year) %>%
  filter(n > 1)

duplicates

cat("Numero di duplicati impresa-anno:", nrow(duplicates), "\n")


# ============================================================
# 6. STRUTTURA PANEL
# ============================================================

# Conversione in pdata.frame
pdata <- pdata.frame(df, index = c("company_id", "year"))

# Informazioni sulla struttura panel
panel_dimension <- pdim(pdata)
panel_dimension

# Verifica se il panel è bilanciato
balanced_panel <- is.pbalanced(pdata)
balanced_panel

cat("Il panel è bilanciato?", balanced_panel, "\n")


# ============================================================
# 7. NUMERO DI OSSERVAZIONI PER IMPRESA
# ============================================================

obs_per_firm <- df %>%
  group_by(company_id) %>%
  summarise(
    company_name = first(company),
    n_years_observed = n(),
    first_year = min(year, na.rm = TRUE),
    last_year = max(year, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  arrange(n_years_observed, company_id)

obs_per_firm

# Distribuzione del numero di anni osservati per impresa
obs_distribution <- obs_per_firm %>%
  count(n_years_observed, name = "n_firms")

obs_distribution

# Stampa tabella sintetica
kable(obs_distribution, caption = "Distribuzione del numero di osservazioni per impresa")


# ============================================================
# 8. NUMERO DI OSSERVAZIONI PER ANNO
# ============================================================

obs_per_year <- df %>%
  group_by(year) %>%
  summarise(
    n_observations = n(),
    n_firms = n_distinct(company_id),
    .groups = "drop"
  )

obs_per_year

kable(obs_per_year, caption = "Numero di osservazioni per anno")


# ============================================================
# 9. MISSING VALUES
# ============================================================

missing_values <- df %>%
  summarise(across(everything(), ~ sum(is.na(.)))) %>%
  pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "missing_count"
  ) %>%
  mutate(
    missing_percentage = round((missing_count / nrow(df)) * 100, 2)
  ) %>%
  arrange(desc(missing_count))

missing_values

kable(missing_values, caption = "Valori mancanti per variabile")

# Variabili con almeno un valore mancante
missing_values_only <- missing_values %>%
  filter(missing_count > 0)

missing_values_only

kable(missing_values_only, caption = "Variabili con valori mancanti")


# ============================================================
# 10. CONTROLLO TIPOLOGIA VARIABILI
# ============================================================

# Controllo classi delle variabili
variable_classes <- data.frame(
  variable = names(df),
  class = sapply(df, class)
)

variable_classes

kable(variable_classes, caption = "Classe delle variabili")


# ============================================================
# 11. CONVERSIONE EVENTUALE DI VARIABILI NUMERICHE LETTE COME TESTO
# ============================================================

# La variabile gross_profit potrebbe essere letta come character.
# Proviamo a convertirla in formato numerico.
# parse_number gestisce eventuali virgole, spazi o simboli.

if ("gross_profit" %in% names(df)) {
  df <- df %>%
    mutate(
      gross_profit = parse_number(as.character(gross_profit))
    )
}

# Ricontrollo struttura dopo conversione
str(df$gross_profit)


# ============================================================
# 12. DEFINIZIONE DELLE VARIABILI PRINCIPALI
# ============================================================

# Variabili dipendenti:
# book_lev_debt_ratio = leverage contabile
# mkt_debt_ratio      = leverage di mercato

# Variabili esplicative firm-specific:
# profitability_ratio
# size_ln_total_assets
# tangible_ratio_fixed_asset_ratio
# effective_tax_rate
# liquidity_ratio
# asset_turn_over
# cashflow_from_operations

# Variabili istituzionali:
# rule_of_law
# financial_sector_rating
# institutional_quality
# macroeconomic_mgt
# accountability_and_corruption
# profit_tax

main_vars <- df %>%
  select(
    book_lev_debt_ratio,
    mkt_debt_ratio,
    profitability_ratio,
    size_ln_total_assets,
    tangible_ratio_fixed_asset_ratio,
    effective_tax_rate,
    liquidity_ratio,
    asset_turn_over,
    cashflow_from_operations,
    rule_of_law,
    financial_sector_rating,
    institutional_quality,
    macroeconomic_mgt,
    accountability_and_corruption,
    profit_tax
  )

# Controllo prime righe
head(main_vars)


# ============================================================
# 13. STATISTICHE DESCRITTIVE BASE
# ============================================================

summary(main_vars)

# Statistiche descrittive dettagliate
descriptive_table <- main_vars %>%
  pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "value"
  ) %>%
  group_by(variable) %>%
  summarise(
    n = sum(!is.na(value)),
    missing = sum(is.na(value)),
    mean = mean(value, na.rm = TRUE),
    sd = sd(value, na.rm = TRUE),
    min = min(value, na.rm = TRUE),
    q1 = quantile(value, 0.25, na.rm = TRUE),
    median = median(value, na.rm = TRUE),
    q3 = quantile(value, 0.75, na.rm = TRUE),
    max = max(value, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    across(
      where(is.numeric),
      ~ round(., 4)
    )
  )

descriptive_table

kable(descriptive_table, caption = "Statistiche descrittive delle variabili principali")


# ============================================================
# 14. STATISTICHE DESCRITTIVE CON PSYCH
# ============================================================

psych_describe <- psych::describe(main_vars)

psych_describe


# ============================================================
# 15. CONTROLLO VALORI ESTREMI
# ============================================================

# Questa tabella aiuta a individuare variabili con min/max molto distanti
# dai quartili, quindi potenziali outlier.

outlier_check <- main_vars %>%
  pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "value"
  ) %>%
  group_by(variable) %>%
  summarise(
    min = min(value, na.rm = TRUE),
    q1 = quantile(value, 0.25, na.rm = TRUE),
    median = median(value, na.rm = TRUE),
    q3 = quantile(value, 0.75, na.rm = TRUE),
    max = max(value, na.rm = TRUE),
    iqr = IQR(value, na.rm = TRUE),
    lower_bound = q1 - 1.5 * iqr,
    upper_bound = q3 + 1.5 * iqr,
    n_outliers = sum(value < lower_bound | value > upper_bound, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    across(
      where(is.numeric),
      ~ round(., 4)
    )
  ) %>%
  arrange(desc(n_outliers))

outlier_check

kable(outlier_check, caption = "Controllo preliminare dei valori estremi")


# ============================================================
# 16. CORRELAZIONE TRA VARIABILI PRINCIPALI
# ============================================================

correlation_matrix <- main_vars %>%
  select(
    book_lev_debt_ratio,
    mkt_debt_ratio,
    profitability_ratio,
    size_ln_total_assets,
    tangible_ratio_fixed_asset_ratio,
    effective_tax_rate,
    liquidity_ratio,
    asset_turn_over,
    rule_of_law,
    financial_sector_rating,
    institutional_quality,
    macroeconomic_mgt,
    accountability_and_corruption,
    profit_tax
  ) %>%
  cor(use = "pairwise.complete.obs")

round(correlation_matrix, 3)


# ============================================================
# 17. GRAFICI ESPLORATIVI
# ============================================================

# 17.1 Distribuzione del leverage contabile

ggplot(df, aes(x = book_lev_debt_ratio)) +
  geom_histogram(bins = 40) +
  labs(
    title = "Distribuzione del leverage contabile",
    x = "Book leverage",
    y = "Frequenza"
  )


# 17.2 Distribuzione del leverage di mercato

ggplot(df, aes(x = mkt_debt_ratio)) +
  geom_histogram(bins = 40) +
  labs(
    title = "Distribuzione del leverage di mercato",
    x = "Market leverage",
    y = "Frequenza"
  )


# 17.3 Andamento medio del leverage contabile nel tempo

mean_booklev_year <- df %>%
  group_by(year) %>%
  summarise(
    mean_book_leverage = mean(book_lev_debt_ratio, na.rm = TRUE),
    .groups = "drop"
  )

ggplot(mean_booklev_year, aes(x = year, y = mean_book_leverage)) +
  geom_line() +
  geom_point() +
  labs(
    title = "Andamento medio del leverage contabile nel tempo",
    x = "Anno",
    y = "Book leverage medio"
  )


# 17.4 Andamento medio del leverage di mercato nel tempo

mean_mktlev_year <- df %>%
  group_by(year) %>%
  summarise(
    mean_market_leverage = mean(mkt_debt_ratio, na.rm = TRUE),
    .groups = "drop"
  )

ggplot(mean_mktlev_year, aes(x = year, y = mean_market_leverage)) +
  geom_line() +
  geom_point() +
  labs(
    title = "Andamento medio del leverage di mercato nel tempo",
    x = "Anno",
    y = "Market leverage medio"
  )


# 17.5 Leverage contabile per impresa

ggplot(df, aes(x = factor(company_id), y = book_lev_debt_ratio)) +
  geom_boxplot() +
  labs(
    title = "Distribuzione del leverage contabile per impresa",
    x = "Impresa",
    y = "Book leverage"
  ) +
  theme(
    axis.text.x = element_text(angle = 90, vjust = 0.5)
  )


# 17.6 Relazione tra dimensione e leverage contabile

ggplot(df, aes(x = size_ln_total_assets, y = book_lev_debt_ratio)) +
  geom_point() +
  geom_smooth(method = "lm", se = FALSE) +
  labs(
    title = "Relazione tra dimensione aziendale e leverage contabile",
    x = "Size - log totale attivo",
    y = "Book leverage"
  )


# 17.7 Relazione tra redditività e leverage contabile

ggplot(df, aes(x = profitability_ratio, y = book_lev_debt_ratio)) +
  geom_point() +
  geom_smooth(method = "lm", se = FALSE) +
  labs(
    title = "Relazione tra redditività e leverage contabile",
    x = "Profitability ratio",
    y = "Book leverage"
  )


# ============================================================
# 18. SALVATAGGIO DELLE TABELLE UTILI
# ============================================================

# Creazione cartella output se non esiste
if (!dir.exists("output")) {
  dir.create("output")
}

# Salvataggio tabelle in formato CSV
write_csv(obs_per_firm, "output/obs_per_firm.csv")
write_csv(obs_distribution, "output/obs_distribution.csv")
write_csv(obs_per_year, "output/obs_per_year.csv")
write_csv(missing_values, "output/missing_values.csv")
write_csv(missing_values_only, "output/missing_values_only.csv")
write_csv(variable_classes, "output/variable_classes.csv")
write_csv(descriptive_table, "output/descriptive_table.csv")
write_csv(outlier_check, "output/outlier_check.csv")
write_csv(as.data.frame(correlation_matrix), "output/correlation_matrix.csv")


# ============================================================
