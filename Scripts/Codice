cat("R-squared:", round(r2_re, 4), "\n")
cat("Adjusted R-squared:", round(adj_r2_re, 4), "\n")
cat("================================================\n")

bp_test_re_vs_pooled <- plmtest(
  pooled_ols,
  type = "bp"
)

bp_test_re_vs_pooled

hausman_test <- phtest(
  fixed_effects,
  random_effects
)

hausman_test

re_results <- data.frame(
  variable = rownames(random_effects_robust),
  estimate = random_effects_robust[, 1],
  robust_se = random_effects_robust[, 2],
  t_value = random_effects_robust[, 3],
  p_value = random_effects_robust[, 4]
) %>%
  mutate(
    estimate = round(estimate, 5),
    robust_se = round(robust_se, 5),
    t_value = round(t_value, 4),
    p_value = round(p_value, 5)
  )

