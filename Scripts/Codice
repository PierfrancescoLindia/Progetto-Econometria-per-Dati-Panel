missing_table <- df %>%
  summarise(across(
    everything(),
    ~ sum(is.na(.))
  )) %>%
  pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "missing"
  ) %>%
  mutate(
    perc_missing = round(100 * missing / nrow(df), 2)
  ) %>%
  filter(missing > 0) %>%
  arrange(desc(missing))

missing_table

write_csv(missing_table, "output/missing_values.csv")


