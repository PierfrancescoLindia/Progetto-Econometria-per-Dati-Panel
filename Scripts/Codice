# ------------------------------------------------------------
# 6.5 Istogrammi limitati variabili problematiche
# ------------------------------------------------------------

plot_limited_hist <- function(data, var, x_min, x_max, file_name, title_text) {
  p <- ggplot(data, aes(x = .data[[var]])) +
    geom_histogram(bins = 40) +
    coord_cartesian(xlim = c(x_min, x_max)) +
    labs(
      title = title_text,
      subtitle = "Scala limitata per migliorare la leggibilità grafica",
      x = var,
      y = "Frequenza"
    ) +
    theme_minimal()
  
  print(p)
  
  ggsave(
    filename = paste0("output/", file_name),
    plot = p,
    width = 8,
    height = 5
  )
}

plot_limited_hist(
  df,
  "book_lev_debt_ratio",
  -1,
  3,
  "hist_book_leverage_limitato.png",
  "Distribuzione del leverage contabile"
)

plot_limited_hist(
  df,
  "liquidity_ratio",
  0,
  10,
  "hist_liquidity_ratio_limitato.png",
  "Distribuzione del liquidity ratio"
)

plot_limited_hist(
  df,
  "effective_tax_rate",
  -1,
  2,
  "hist_effective_tax_rate_limitato.png",
  "Distribuzione dell'effective tax rate"
)

plot_limited_hist(
  df,
  "tangible_ratio_fixed_asset_ratio",
