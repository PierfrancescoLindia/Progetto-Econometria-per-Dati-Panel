# ============================================================
# 15. MODELLO PANEL DINAMICO
# ARELLANO-BOND / DIFFERENCE GMM
# ============================================================

dynamic_ab <- pgmm(
  book_lev_debt_ratio ~
    lag(book_lev_debt_ratio, 1) +
    profitability_ratio +
    size_ln_total_assets +
    tangible_ratio_fixed_asset_ratio +
    effective_tax_rate +
    liquidity_ratio +
    asset_turn_over +
    rule_of_law +
    financial_sector_rating +
    institutional_quality +
    macroeconomic_mgt +
    accountability_and_corruption |
    lag(book_lev_debt_ratio, 2:3),
  data = pdata,
  effect = "individual",
  model = "twosteps",
  transformation = "d"
)

summary(dynamic_ab)

summary_dynamic_ab <- summary(dynamic_ab, robust = TRUE)

summary_dynamic_ab


# ------------------------------------------------------------
# 15.1 Test diagnostici Arellano-Bond
# ------------------------------------------------------------

ar1_test <- mtest(dynamic_ab, order = 1)
ar2_test <- mtest(dynamic_ab, order = 2)
sargan_test <- sargan(dynamic_ab)

ar1_test
ar2_test
sargan_test


# ------------------------------------------------------------
# 15.2 Estrazione risultati modello dinamico
# ------------------------------------------------------------

dynamic_coefficients <- summary_dynamic_ab$coefficients

dynamic_results <- data.frame(
  variable = rownames(dynamic_coefficients),
  estimate = dynamic_coefficients[, 1],
  robust_se = dynamic_coefficients[, 2],
  z_value = dynamic_coefficients[, 3],
  p_value = dynamic_coefficients[, 4]
) %>%
  mutate(
    estimate = round(estimate, 5),
    robust_se = round(robust_se, 5),
    z_value = round(z_value, 4),
    p_value = round(p_value, 5)
  )

dynamic_results

n_obs_dynamic <- nobs(dynamic_ab)

cat("\n================ MODELLO DINAMICO ARELLANO-BOND ================\n")
cat("Numero osservazioni utilizzate:", n_obs_dynamic, "\n")
cat("===============================================================\n")


diagnostic_tests_dynamic <- data.frame(
  test = c(
    "Arellano-Bond AR(1)",
    "Arellano-Bond AR(2)",
    "Sargan test"
  ),
  statistic = c(
    as.numeric(ar1_test$statistic),
    as.numeric(ar2_test$statistic),
    as.numeric(sargan_test$statistic)
  ),
  p_value = c(
    ar1_test$p.value,
    ar2_test$p.value,
    sargan_test$p.value
  )
) %>%
  mutate(
    statistic = round(statistic, 4),
    p_value = ifelse(p_value < 0.001, "<0.001", as.character(round(p_value, 4)))
  )

diagnostic_tests_dynamic


# ------------------------------------------------------------
# 15.3 Confronto Random Effects statico vs Arellano-Bond
# ------------------------------------------------------------

re_static_table <- format_model(
  random_effects_robust,
  "Random_Effects_statico"
)

dynamic_table <- dynamic_results %>%
  mutate(
    stars = case_when(
      p_value < 0.01 ~ "***",
      p_value < 0.05 ~ "**",
      p_value < 0.10 ~ "*",
      TRUE ~ ""
    ),
    Dynamic_Arellano_Bond = paste0(
      estimate,
      stars,
      "\n(",
      robust_se,
      ")"
    )
  ) %>%
  select(variable, Dynamic_Arellano_Bond)

comparison_static_dynamic <- re_static_table %>%
  full_join(dynamic_table, by = "variable")

comparison_static_dynamic

write_csv(dynamic_results, "output/dynamic_arellano_bond_results.csv")
write_csv(diagnostic_tests_dynamic, "output/dynamic_arellano_bond_tests.csv")
write_csv(comparison_static_dynamic, "output/confronto_statico_dinamico.csv")


