numeric_vars <- vars_descr %>%
  select(-company_id, -company, -year)


# ------------------------------------------------------------
# 6.1 Tabella statistiche descrittive
# ------------------------------------------------------------

desc_table <- numeric_vars %>%
  pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "value"
  ) %>%
  group_by(variable) %>%
  summarise(
    n = sum(!is.na(value)),
    missing = sum(is.na(value)),
    mean = mean(value, na.rm = TRUE),
    sd = sd(value, na.rm = TRUE),
    min = min(value, na.rm = TRUE),
    q1 = quantile(value, 0.25, na.rm = TRUE),
    median = median(value, na.rm = TRUE),
    q3 = quantile(value, 0.75, na.rm = TRUE),
    max = max(value, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    across(where(is.numeric), ~ round(., 4))
  )

desc_table

kable(desc_table, caption = "Statistiche descrittive delle principali variabili")

write_csv(desc_table, "output/statistiche_descrittive_principali.csv")


# ------------------------------------------------------------
# 6.2 Controllo outlier con regola IQR
# ------------------------------------------------------------

outlier_table <- numeric_vars %>%
  pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "value"
  ) %>%
  group_by(variable) %>%
  summarise(
    q1 = quantile(value, 0.25, na.rm = TRUE),
    q3 = quantile(value, 0.75, na.rm = TRUE),
    iqr = IQR(value, na.rm = TRUE),
    lower_bound = q1 - 1.5 * iqr,
    upper_bound = q3 + 1.5 * iqr,
    n_outliers = sum(value < lower_bound | value > upper_bound, na.rm = TRUE),
    perc_outliers = round(100 * n_outliers / sum(!is.na(value)), 2),
    min = min(value, na.rm = TRUE),
    max = max(value, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    across(where(is.numeric), ~ round(., 4))
  ) %>%
  arrange(desc(n_outliers))

outlier_table

kable(outlier_table, caption = "Controllo dei valori estremi con regola IQR")

write_csv(outlier_table, "output/outlier_table_iqr.csv")


