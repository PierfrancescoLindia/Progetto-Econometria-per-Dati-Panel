# ============================================================
# 7. SPECIFICAZIONE BASE DEI MODELLI STATICI
# ============================================================

formula_base <- book_lev_debt_ratio ~
  profitability_ratio +
  size_ln_total_assets +
  tangible_ratio_fixed_asset_ratio +
  effective_tax_rate +
  liquidity_ratio +
  asset_turn_over +
  rule_of_law +
  financial_sector_rating +
  institutional_quality +
  macroeconomic_mgt +
  accountability_and_corruption


# ============================================================
# 8. MODELLO POOLED OLS
# ============================================================

pooled_ols <- plm(
  formula_base,
  data = pdata,
  model = "pooling"
)

summary(pooled_ols)

pooled_ols_robust <- coeftest(
  pooled_ols,
  vcov = vcovHC(
    pooled_ols,
    type = "HC1",
    cluster = "group"
  )
)

pooled_ols_robust

n_obs_pooled <- nobs(pooled_ols)
r2_pooled <- summary(pooled_ols)$r.squared["rsq"]
adj_r2_pooled <- summary(pooled_ols)$r.squared["adjrsq"]

cat("\n================ POOLED OLS ================\n")
cat("Numero osservazioni utilizzate:", n_obs_pooled, "\n")
cat("R-squared:", round(r2_pooled, 4), "\n")
cat("Adjusted R-squared:", round(adj_r2_pooled, 4), "\n")
cat("============================================\n")

pooled_results <- data.frame(
  variable = rownames(pooled_ols_robust),
  estimate = pooled_ols_robust[, 1],
  robust_se = pooled_ols_robust[, 2],
  t_value = pooled_ols_robust[, 3],
  p_value = pooled_ols_robust[, 4]
) %>%
  mutate(
    estimate = round(estimate, 5),
    robust_se = round(robust_se, 5),
    t_value = round(t_value, 4),
    p_value = round(p_value, 5)
  )

pooled_results

write_csv(pooled_results, "output/pooled_ols_results.csv")


# ============================================================
# 9. MODELLO A EFFETTI FISSI
# ============================================================

fixed_effects <- plm(
  formula_base,
  data = pdata,
  model = "within",
  effect = "individual"
)

summary(fixed_effects)

fixed_effects_robust <- coeftest(
  fixed_effects,
  vcov = vcovHC(
    fixed_effects,
    type = "HC1",
    cluster = "group"
  )
)

fixed_effects_robust

n_obs_fe <- nobs(fixed_effects)
r2_fe <- summary(fixed_effects)$r.squared["rsq"]
adj_r2_fe <- summary(fixed_effects)$r.squared["adjrsq"]

cat("\n================ FIXED EFFECTS ================\n")
cat("Numero osservazioni utilizzate:", n_obs_fe, "\n")
cat("R-squared within:", round(r2_fe, 4), "\n")
cat("Adjusted R-squared:", round(adj_r2_fe, 4), "\n")
cat("===============================================\n")

f_test_fe_vs_pooled <- pFtest(fixed_effects, pooled_ols)

f_test_fe_vs_pooled

fe_results <- data.frame(
  variable = rownames(fixed_effects_robust),
  estimate = fixed_effects_robust[, 1],
  robust_se = fixed_effects_robust[, 2],
  t_value = fixed_effects_robust[, 3],
  p_value = fixed_effects_robust[, 4]
) %>%
  mutate(
    estimate = round(estimate, 5),
    robust_se = round(robust_se, 5),
    t_value = round(t_value, 4),
    p_value = round(p_value, 5)
  )

fe_results

write_csv(fe_results, "output/fixed_effects_results.csv")


