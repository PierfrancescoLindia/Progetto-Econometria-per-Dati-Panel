# ============================================================
# 11. CONFRONTO MODELLI STATICI PANEL
# ============================================================

pooled_robust <- coeftest(
  pooled_ols,
  vcov = vcovHC(pooled_ols, type = "HC1", cluster = "group")
)

fe_robust <- coeftest(
  fixed_effects,
  vcov = vcovHC(fixed_effects, type = "HC1", cluster = "group")
)

re_robust <- coeftest(
  random_effects,
  vcov = vcovHC(random_effects, type = "HC1", cluster = "group")
)


format_model <- function(model_output, model_name) {
  data.frame(
    variable = rownames(model_output),
    estimate = model_output[, 1],
    robust_se = model_output[, 2],
    p_value = model_output[, 4]
  ) %>%
    mutate(
      stars = case_when(
        p_value < 0.01 ~ "***",
        p_value < 0.05 ~ "**",
        p_value < 0.10 ~ "*",
        TRUE ~ ""
      ),
      result = paste0(
        round(estimate, 4),
        stars,
        "\n(",
        round(robust_se, 4),
        ")"
      )
    ) %>%
    select(variable, !!model_name := result)
}

pooled_table <- format_model(pooled_robust, "Pooled_OLS")
fe_table <- format_model(fe_robust, "Fixed_Effects")
re_table <- format_model(re_robust, "Random_Effects")

comparison_table <- pooled_table %>%
  full_join(fe_table, by = "variable") %>%
  full_join(re_table, by = "variable")

comparison_table

model_stats <- data.frame(
  statistic = c(
    "Observations",
    "R-squared",
    "Adjusted R-squared"
  ),
  Pooled_OLS = c(
    nobs(pooled_ols),
    round(summary(pooled_ols)$r.squared["rsq"], 4),
    round(summary(pooled_ols)$r.squared["adjrsq"], 4)
  ),
  Fixed_Effects = c(
    nobs(fixed_effects),
    round(summary(fixed_effects)$r.squared["rsq"], 4),
    round(summary(fixed_effects)$r.squared["adjrsq"], 4)
  ),
  Random_Effects = c(
    nobs(random_effects),
    round(summary(random_effects)$r.squared["rsq"], 4),
    round(summary(random_effects)$r.squared["adjrsq"], 4)
  )
)

model_stats

test_results <- data.frame(
  test = c(
    "F test: Fixed Effects vs Pooled OLS",
    "Breusch-Pagan LM: Random Effects vs Pooled OLS",
    "Hausman test: Fixed Effects vs Random Effects"
  ),
  statistic = c(
    round(as.numeric(f_test_fe_vs_pooled$statistic), 4),
    round(as.numeric(bp_test_re_vs_pooled$statistic), 4),
    round(as.numeric(hausman_test$statistic), 4)
  ),
  p_value = c(
    f_test_fe_vs_pooled$p.value,
    bp_test_re_vs_pooled$p.value,
    hausman_test$p.value
  )
) %>%
  mutate(
    p_value = ifelse(p_value < 0.001, "<0.001", round(p_value, 4))
  )

test_results

write_csv(comparison_table, "output/comparison_static_models.csv")
write_csv(model_stats, "output/model_stats_static_models.csv")
write_csv(test_results, "output/test_results_static_models.csv")


# ============================================================
# 12. ANALISI DI ROBUSTEZZA 1
# RANDOM EFFECTS CON VARIABILI WINSORIZZATE
# ============================================================

winsorize <- function(x, probs = c(0.01, 0.99)) {
  q <- quantile(x, probs = probs, na.rm = TRUE)
  x_w <- pmin(pmax(x, q[1]), q[2])
  return(x_w)
}

df_winsor <- df %>%
  mutate(
    book_lev_debt_ratio_w = winsorize(book_lev_debt_ratio),
    profitability_ratio_w = winsorize(profitability_ratio),
    tangible_ratio_fixed_asset_ratio_w = winsorize(tangible_ratio_fixed_asset_ratio),
    effective_tax_rate_w = winsorize(effective_tax_rate),
    liquidity_ratio_w = winsorize(liquidity_ratio),
    asset_turn_over_w = winsorize(asset_turn_over)
  )

winsor_compare <- df_winsor %>%
  select(
    book_lev_debt_ratio,
    book_lev_debt_ratio_w,
    profitability_ratio,
    profitability_ratio_w,
    tangible_ratio_fixed_asset_ratio,
    tangible_ratio_fixed_asset_ratio_w,
    effective_tax_rate,
    effective_tax_rate_w,
    liquidity_ratio,
    liquidity_ratio_w,
    asset_turn_over,
    asset_turn_over_w
  ) %>%
  pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "value"
  ) %>%
  group_by(variable) %>%
  summarise(
    n = sum(!is.na(value)),
    mean = mean(value, na.rm = TRUE),
    sd = sd(value, na.rm = TRUE),
    min = min(value, na.rm = TRUE),
    median = median(value, na.rm = TRUE),
    max = max(value, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(across(where(is.numeric), ~ round(., 4)))

winsor_compare

pdata_winsor <- pdata.frame(
  df_winsor,
  index = c("company_id", "year")
)

formula_re_winsor <- book_lev_debt_ratio_w ~
  profitability_ratio_w +
  size_ln_total_assets +
  tangible_ratio_fixed_asset_ratio_w +
  effective_tax_rate_w +
  liquidity_ratio_w +
  asset_turn_over_w +
  rule_of_law +
  financial_sector_rating +
  institutional_quality +
  macroeconomic_mgt +
  accountability_and_corruption

random_effects_winsor <- plm(
  formula_re_winsor,
  data = pdata_winsor,
  model = "random",
  effect = "individual"
)

summary(random_effects_winsor)

random_effects_winsor_robust <- coeftest(
  random_effects_winsor,
  vcov = vcovHC(
    random_effects_winsor,
    type = "HC1",
    cluster = "group"
  )
)

random_effects_winsor_robust

n_obs_re_winsor <- nobs(random_effects_winsor)
r2_re_winsor <- summary(random_effects_winsor)$r.squared["rsq"]
adj_r2_re_winsor <- summary(random_effects_winsor)$r.squared["adjrsq"]

cat("\n================ RANDOM EFFECTS WINSORIZZATO ================\n")
cat("Numero osservazioni utilizzate:", n_obs_re_winsor, "\n")
cat("R-squared:", round(r2_re_winsor, 4), "\n")
cat("Adjusted R-squared:", round(adj_r2_re_winsor, 4), "\n")
cat("=============================================================\n")

re_winsor_results <- data.frame(
  variable = rownames(random_effects_winsor_robust),
  estimate = random_effects_winsor_robust[, 1],
  robust_se = random_effects_winsor_robust[, 2],
  t_value = random_effects_winsor_robust[, 3],
  p_value = random_effects_winsor_robust[, 4]
) %>%
  mutate(
    estimate = round(estimate, 5),
    robust_se = round(robust_se, 5),
    t_value = round(t_value, 4),
    p_value = round(p_value, 5)
  )

re_winsor_results

re_original_table <- format_model(
  random_effects_robust,
  "Random_Effects_originale"
)

re_winsor_table <- format_model(
  random_effects_winsor_robust,
  "Random_Effects_winsorizzato"
)

comparison_re_winsor <- re_original_table %>%
  full_join(re_winsor_table, by = "variable")

comparison_re_winsor

write_csv(df_winsor, "output/dataset_winsorizzato.csv")
write_csv(winsor_compare, "output/confronto_descrittivo_winsor.csv")
write_csv(re_winsor_results, "output/random_effects_winsor_results.csv")
write_csv(comparison_re_winsor, "output/confronto_re_originale_winsor.csv")


